# Case-insensitive tab completion
set completion-ignore-case on

# Show all completions on first TAB if ambiguous (instead of requiring two TABs)
set show-all-if-ambiguous on

# Color completions by file type (like ls)
set colored-stats on

# Append / to completed directory names
set mark-directories on
set mark-symlinked-directories on

# Show common prefix in color before cycling
set colored-completion-prefix on

# Don't ring bell on ambiguous completion
set bell-style none

# Up/Down arrow search history based on typed prefix
"\e[A": history-search-backward
"\e[B": history-search-forward

# Ctrl-Left/Right to move by word
"\e[1;5D": backward-word
"\e[1;5C": forward-word
